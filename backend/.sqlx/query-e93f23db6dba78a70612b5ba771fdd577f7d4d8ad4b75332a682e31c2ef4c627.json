{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            id,\n            event_type,\n            source_class,\n            ST_Y(location::geometry) AS \"lat!: f64\",\n            ST_X(location::geometry) AS \"lon!: f64\",\n            payload,\n            received_at\n        FROM raw_events\n        WHERE received_at >= $1\n          AND id NOT IN (\n              SELECT UNNEST(event_ids) FROM incidents WHERE status != 'CLOSED'\n          )\n        ORDER BY received_at ASC\n        ",
