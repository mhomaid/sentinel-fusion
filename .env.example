# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_secret
POSTGRES_DB=sentinel_fusion
POSTGRES_PORT=5432

# Full connection URL consumed by SQLx
DATABASE_URL=postgres://sentinel:sentinel_secret@localhost:5432/sentinel_fusion

# ── API server ───────────────────────────────────────────────────────────────
PORT=8080

# ── Fusion engine ────────────────────────────────────────────────────────────
# How often the fusion cycle runs (seconds)
FUSION_INTERVAL_SECS=30

# Sliding event window fed into each cycle (seconds)
FUSION_WINDOW_SECS=300

# Geohash precision for spatial clustering (7 ≈ 150m × 150m)
FUSION_GEOHASH_PRECISION=7

# Radius for merging adjacent geohash cells (meters)
FUSION_PROXIMITY_METERS=300

# Seconds without new events before an open incident is closed
FUSION_STALE_CLOSE_SECS=900

# ── SQLx compile-time query checking ─────────────────────────────────────────
# Set to true to use cached .sqlx queries for offline builds (CI)
SQLX_OFFLINE=false

# ── Frontend ──────────────────────────────────────────────────────────────────
# Get your free token at https://account.mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_token_here

# ── Observability ─────────────────────────────────────────────────────────────
RUST_LOG=info

# ── UAT database (used by db-migrations/migrations.py --env uat) ─────────────
# Create .env.uat at the repo root with this variable set.
UAT_DATABASE_URL=postgres://sentinel:password@uat-host:5432/sentinel_fusion

# ── Production database — Supabase ───────────────────────────────────────────
# Create .env.prod at the repo root with this variable set.
# Connection string from: Supabase Dashboard → Settings → Database → Connection string
# Use the "URI" format (not the pooler URL) for migrations.
SUPABASE_DATABASE_URL=postgresql://postgres:[your-password]@db.[your-project-ref].supabase.co:5432/postgres
